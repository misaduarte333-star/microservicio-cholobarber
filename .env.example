# Configuración para ejecución LOCAL conectada a servicios REMOTOS
# Copia este archivo como .env y completa con tus valores reales de Easypanel

PORT=3001
NODE_ENV=development

# --- SEGURIDAD UNIFICADA ---
# Si lo dejas vacío, las rutas de administración (/api/agents) estarán abiertas.
ADMIN_TOKEN=tu_token_seguro_aqui

# --- SUPABASE (Gestión de Agentes y Citas) ---
SUPABASE_URL=https://zzkryfmfoucxxmimrhyh.supabase.co
SUPABASE_KEY=tu_service_role_key_aqui

# --- EVOLUTION API (WhatsApp) ---
# Usa la URL pública que tienes en Easypanel
EVOLUTION_API_URL=https://cholobot-evolution.ada8bf.easypanel.host
EVOLUTION_API_KEY=tu_api_key_de_evolution
EVOLUTION_INSTANCE=barberia

# --- INTELIGENCIA ARTIFICIAL ---
OPENAI_API_KEY=tu_key_aqui
ANTHROPIC_API_KEY=tu_key_aqui
# GOOGLE_API_KEY=

# --- REDIS / POSTGRES ---
# Para pruebas locales rápidas, puedes activar MOCK_MODE para no necesitar Redis local.
# Si quieres usar los reales, necesitas exponer los puertos en Easypanel.
MOCK_MODE=true

# DATABASE_URL=postgresql://evouser:1234@localhost:5432/evolutiondb
# REDIS_URL=redis://localhost:6379

# --- NGROK (Opcional para recibir webhooks locales) ---
# NGROK_AUTHTOKEN=
# NGROK_API_URL=http://localhost:4040
