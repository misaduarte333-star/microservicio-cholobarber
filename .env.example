# ============================================================================
# CRÍTICO PARA PRODUCCIÓN (EasyPanel/Docker)
# URL pública del microservicio CholoBot. Debe ser el dominio real del contenedor
# en EasyPanel p.ej: https://cholobot.ada8bf.easypanel.host
# Sin esta variable, el webhook de Evolution API se registrará apuntando a
# la red interna del contenedor (0.0.0.0) y los mensajes no llegarán.
# ============================================================================
NEXT_PUBLIC_APP_URL=https://tu-dominio-publico.easypanel.host

# Evolution API
EVOLUTION_API_URL=https://cholobot-evolution.ada8bf.easypanel.host
EVOLUTION_API_KEY=your-evolution-api-key
EVOLUTION_INSTANCE=barberia
